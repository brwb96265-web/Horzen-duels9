-- [ CORE LOGIC LOOPS ]
task.spawn(function()
    while task.wait() do
        -- Instant Grab Logic
        if Horzen.InstantGrab or Horzen.AutoSteal then
            pcall(function()
                for _, p in ipairs(workspace:GetDescendants()) do
                    if p:IsA("ProximityPrompt") and p.Enabled then
                        if (Player.Character.HumanoidRootPart.Position - p.Parent.WorldPosition).Magnitude < 30 then
                            fireproximityprompt(p)
                        end
                    end
                end
            end)
        end
        
        -- Auto Steal / Deposit Cycle
        if Horzen.AutoSteal then
            pcall(function()
                local hasItem = Player.Character:FindFirstChild("Brainrot") or Player:GetAttribute("Stealing")
                if not hasItem then
                    -- TP to Random Enemy Base Brainrot
                    for _,b in pairs(workspace.Bases:GetChildren()) do
                        if b.Name ~= Player.Name and b:FindFirstChild("Brainrot") then
                            Player.Character.HumanoidRootPart.CFrame = b.Brainrot.CFrame
                            break
                        end
                    end
                elseif Horzen.BasePos then
                    -- TP Home
                    Player.Character.HumanoidRootPart.CFrame = CFrame.new(Horzen.BasePos)
                end
            end)
        end

        -- Kill Aura
        if Horzen.KillAura then
            for _, v in ipairs(game:GetService("Players"):GetPlayers()) do
                if v ~= Player and v.Character and (Player.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude < 18 then
                    VIM:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                end
            end
        end
    end
end)

-- Character Loop
game:GetService("RunService").Heartbeat:Connect(function()
    pcall(function()
        local hum = Player.Character:FindFirstChildOfClass("Humanoid")
        hum.WalkSpeed = Horzen.WalkSpeed
        if Horzen.AntiRagdoll then
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        end
    end)
end)

-- Infinite Jump
game:GetService("UserInputService").JumpRequest:Connect(function()
    if Horzen.InfJump then Player.Character.Humanoid:ChangeState(3) end
end)

