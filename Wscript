-- [ Combat: Kill Aura / Hitbox ]
task.spawn(function()
    while task.wait(0.1) do
        if Horzen.KillAura then
            pcall(function()
                for _, v in ipairs(game:GetService("Players"):GetPlayers()) do
                    if v ~= Player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                        local dist = (Player.Character.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
                        if dist < 15 then
                            -- محاكاة ضرب الخصم (يعتمد على سلاحك المجهز)
                            VIM:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                        end
                    end
                end
            end)
        end
    end
end)

-- [ Logic: Flash Farm & Auto Grab ]
task.spawn(function()
    while task.wait() do
        if Horzen.FlashFarm then
            local stealing = Player:GetAttribute("Stealing")
            local target = stealing and Pos.Home or (Horzen.FarmSide == "Left" and Pos.Left or Pos.Right)
            
            if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                Player.Character.HumanoidRootPart.CFrame = CFrame.new(target)
            end
        end
        
        if Horzen.InstantGrab or Horzen.FlashFarm then
            for _, p in ipairs(workspace:GetDescendants()) do
                if p:IsA("ProximityPrompt") and p.Enabled then
                    if (Player.Character.HumanoidRootPart.Position - p.Parent.WorldPosition).Magnitude < 25 then
                        fireproximityprompt(p)
                    end
                end
            end
        end
    end
end)

-- [ Anti-Ragdoll & Movement Bypass ]
RunService.Stepped:Connect(function()
    if Horzen.AntiRagdoll and Player.Character and Player.Character:FindFirstChild("Humanoid") then
        Player.Character.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        Player.Character.Humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
    end
    if Player.Character and Player.Character:FindFirstChild("Humanoid") then
        Player.Character.Humanoid.WalkSpeed = Horzen.WalkSpeed
        Player.Character.Humanoid.JumpPower = Horzen.JumpPower
    end
end)

