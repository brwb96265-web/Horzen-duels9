if not game:IsLoaded() then game.Loaded:Wait() end

local Player = game:GetService("Players").LocalPlayer
local HRP = Player.Character:WaitForChild("HumanoidRootPart")

local Settings = {
    AutoLeft = false,
    AutoRight = false,
    AutoGrab = true,
    FastTP = true
}

-- [ Precise Coordinates for Steal a Brainrots ]
local Positions = {
    Home = Vector3.new(0, 3.5, 58),
    LeftEnemy = Vector3.new(-38, 3.5, -2),
    RightEnemy = Vector3.new(38, 3.5, -2)
}

-- [ Instant TP Function ]
local function InstantTP(TargetPos)
    if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        Player.Character.HumanoidRootPart.CFrame = CFrame.new(TargetPos)
    end
end

-- [ Super Fast Auto Interaction ]
task.spawn(function()
    while task.wait() do
        if Settings.AutoGrab or Settings.AutoLeft or Settings.AutoRight then
            pcall(function()
                for _, v in ipairs(workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") and v.Enabled then
                        -- High Range Grab
                        local dist = (Player.Character.HumanoidRootPart.Position - v.Parent.WorldPosition).Magnitude
                        if dist < 25 then
                            fireproximityprompt(v)
                        end
                    end
                end
            end)
        end
    end
end)

-- [ The Real Steal Loop ]
task.spawn(function()
    while task.wait(0.3) do
        if Settings.AutoLeft then
            local stealing = Player:GetAttribute("Stealing")
            if not stealing then
                InstantTP(Positions.LeftEnemy)
            else
                InstantTP(Positions.Home)
            end
        elseif Settings.AutoRight then
            local stealing = Player:GetAttribute("Stealing")
            if not stealing then
                InstantTP(Positions.RightEnemy)
            else
                InstantTP(Positions.Home)
            end
        end
    end
end)

