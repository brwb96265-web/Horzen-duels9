-- [ FUNCTION: CREATE BUTTON ]
local function MakeButton(text, callback, isRed)
    local btn = Instance.new("TextButton", ButtonContainer)
    btn.Size = UDim2.new(0.9, 0, 0, 45)
    btn.Text = text
    btn.Font = Enum.Font.GothamBold
    btn.TextColor3 = isRed and Color3.fromRGB(255, 100, 100) or Color3.new(1,1,1)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.BorderSizePixel = 0
    Instance.new("UICorner", btn)

    local state = false
    btn.MouseButton1Click:Connect(function()
        if text:find("Auto") or text == "Hover" then
            state = not state
            btn.BackgroundColor3 = state and Color3.fromRGB(0, 150, 100) or Color3.fromRGB(45, 45, 45)
            callback(state)
        else
            callback() -- Instant action for Tp/Play
        end
    end)
    return btn
end

