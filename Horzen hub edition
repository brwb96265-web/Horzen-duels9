AddFeature("Safe Inf Jump", Cyan, function(v) _G.InfJ = v end, true)
AddFeature("Hover Fly", Cyan, function(v) _G.Hv = v end, true)
AddFeature("Auto Left", Red, function(v) _G.AL = v _G.AR = false end, true)
AddFeature("Auto Right", Red, function(v) _G.AR = v _G.AL = false end, true)
AddFeature("Tp Left Enemy", Red, function() Player.Character.HumanoidRootPart.CFrame = CFrame.new(-45, 5, 0) end, false)
AddFeature("Tp Right Enemy", Red, function() Player.Character.HumanoidRootPart.CFrame = CFrame.new(45, 5, 0) end, false)
AddFeature("Drop Brainrot", Cyan, function() game:GetService("VirtualInputManager"):SendKeyEvent(true, "G", false, game) end, false)
AddFeature("Tp Down", Cyan, function() Player.Character.HumanoidRootPart.CFrame *= CFrame.new(0, -15, 0) end, false)
AddFeature("Play Left", Cyan, function() Player.Character.HumanoidRootPart.CFrame = CFrame.new(-45, 5, 0) task.wait(0.1) game:GetService("VirtualInputManager"):SendKeyEvent(true, "E", false, game) end, false)
AddFeature("Play Right", Cyan, function() Player.Character.HumanoidRootPart.CFrame = CFrame.new(45, 5, 0) task.wait(0.1) game:GetService("VirtualInputManager"):SendKeyEvent(true, "Q", false, game) end, false)
AddFeature("Xray Walls", Cyan, function(v) for _,p in pairs(workspace:GetDescendants()) do if p:IsA("BasePart") then p.Transparency = v and 0.5 or 0 end end end, true)

