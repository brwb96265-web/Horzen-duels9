-- [ BUTTON FACTORY ]
local function Add(name, isToggle, color, callback)
    local btnFrame = Instance.new("Frame", Scroll)
    btnFrame.Size = UDim2.new(0.95, 0, 0, 38)
    btnFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Instance.new("UICorner", btnFrame)
    local stroke = Instance.new("UIStroke", btnFrame)
    stroke.Color = Color3.fromRGB(40, 40, 40)

    local btn = Instance.new("TextButton", btnFrame)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.Text = name
    btn.BackgroundTransparency = 1
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 13

    local active = (name == "Anti Ragdoll") and _G.AntiRagdoll or false
    if active then 
        btnFrame.BackgroundColor3 = color
        stroke.Color = color
    end

    btn.MouseButton1Click:Connect(function()
        if isToggle then
            active = not active
            btnFrame.BackgroundColor3 = active and color or Color3.fromRGB(20, 20, 20)
            stroke.Color = active and color or Color3.fromRGB(40, 40, 40)
            callback(active)
        else
            callback()
        end
    end)
end

