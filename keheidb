    HORZEN HUB - STEAL A BRAINROTS (v5.0)
    - FASTEST TP FARM (FLASH MODE)
    - INSTANT GRAB & DEPOSIT
]]

if not game:IsLoaded() then game.Loaded:Wait() end

local Player = game:GetService("Players").LocalPlayer
local RunService = game:GetService("RunService")
local VIM = game:GetService("VirtualInputManager")

local Settings = {
    AutoFarmLeft = false,
    AutoFarmRight = false,
    FastGrab = true,
    Discord = "https://discord.gg/Stph7N2QQv"
}

-- [ Accurate Positions for Flash TP ]
local Positions = {
    Home = Vector3.new(0, 3.5, 60), -- Your Base
    LeftEnemy = Vector3.new(-38, 3.5, 0), -- Left Base
    RightEnemy = Vector3.new(38, 3.5, 0) -- Right Base
}

-- [ Flash TP Function ]
local function FlashTP(target)
    if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        Player.Character.HumanoidRootPart.CFrame = CFrame.new(target)
    end
end

-- [ Instant Interaction (No Delay) ]
task.spawn(function()
    while task.wait() do
        if Settings.FastGrab or Settings.AutoFarmLeft or Settings.AutoFarmRight then
            pcall(function()
                for _, prompt in ipairs(workspace:GetDescendants()) do
                    if prompt:IsA("ProximityPrompt") and prompt.Enabled then
                        local char = Player.Character
                        if char and (char.HumanoidRootPart.Position - prompt.Parent.WorldPosition).Magnitude < 25 then
                            fireproximityprompt(prompt)
                        end
                    end
                end
            end)
        end
    end
end)

-- [ GOD MODE FARM LOOP ]
task.spawn(function()
    while task.wait(0.1) do -- Fast Loop for Flash TP
        if Settings.AutoFarmLeft then
            local isStealing = Player:GetAttribute("Stealing")
            if not isStealing then
                FlashTP(Positions.LeftEnemy)
            else
                FlashTP(Positions.Home)
            end
        elseif Settings.AutoFarmRight then
            local isStealing = Player:GetAttribute("Stealing")
            if not isStealing then
                FlashTP(Positions.RightEnemy)
            else
                FlashTP(Positions.Home)
            end
        end
    end
end)

