-- [ PERFORMANCE ENGINE - NO LAG ]
task.spawn(function()
    while task.wait(0.05) do -- Fast Refresh
        if _G.AutoSteal then
            pcall(function()
                local char = Player.Character
                local root = char.HumanoidRootPart
                local hasItem = char:FindFirstChild("Brainrot") or Player:GetAttribute("Stealing")
                
                if not hasItem then
                    -- TP to Enemy (Precise)
                    local pos = _G.TargetSide == "Left" and Vector3.new(-48, 8, 0) or Vector3.new(48, 8, 0)
                    root.CFrame = CFrame.new(pos)
                    InstantSteal()
                else
                    -- TP to Deposit (Instant)
                    local myBase = GetMyBase()
                    if myBase then root.CFrame = myBase end
                end
            end)
        end
    end
end)

RunService.Stepped:Connect(function()
    pcall(function()
        local char = Player.Character
        if _G.AntiRag then
            char.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
            char.Humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        end
        if _G.InfJ and UIS:IsKeyDown(Enum.KeyCode.Space) then root.Velocity = Vector3.new(0, 55, 0) end
        if _G.Hv then root.Velocity = Vector3.new(0, 3, 0) root.CFrame *= CFrame.new(0,0,-0.4) end
    end)
end)
