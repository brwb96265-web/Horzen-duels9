-- [ BUTTON FACTORY ]
local function Btn(name, color, isToggle, callback)
    local b = Instance.new("TextButton", Scroll)
    b.Size = UDim2.new(1, 0, 0, 35)
    b.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    b.Text = name
    b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.GothamBold
    b.TextSize = 12
    Instance.new("UICorner", b)
    
    local active = false
    b.MouseButton1Click:Connect(function()
        if isToggle then
            active = not active
            b.BackgroundColor3 = active and color or Color3.fromRGB(20, 20, 20)
            callback(active)
        else
            callback()
        end
    end)
end

