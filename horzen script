-- [ SETTINGS ]
_G.AutoSteal = false
_G.TargetSide = "Left" -- Left or Right
_G.InfJ = false
_G.Hv = false
_G.AntiRag = true
_G.GrabDistance = 35

-- [ CORE FUNCTIONS - THE POWER ]
local function GetMyBase()
    for _,v in pairs(workspace.Bases:GetChildren()) do
        if v:FindFirstChild("Owner") and v.Owner.Value == Player.Name then
            return v.Claim.CFrame
        end
    end
    return nil
end

local function InstantSteal()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.Parent.Name:lower():find("brainrot") and v.Enabled then
            local dist = (Player.Character.HumanoidRootPart.Position - v.Parent.Position).Magnitude
            if dist < _G.GrabDistance then
                fireproximityprompt(v)
            end
        end
    end
end

